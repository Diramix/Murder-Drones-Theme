{
    "name": "murder-drones-theme",
    "description": "BITE ME!",
    "author": "Diramix",
    "license": "CC0-1.0",
    "directories": {
        "doc": "doc"
    },
    "scripts": {
        "build": "ymtm build",
        "build:nextmusic": "ymtm build nextmusic",
        "build:pulsesync": "ymtm build pulsesync",
        "build:web": "ymtm build web"
    },
    "build": {
        "package": [
            "nextmusic",
            "pulsesync",
            "web"
        ]
    },
    "nextmusic": {
        "zip": {
            "artifactName": "${theme.name}_${theme.version}_${build.package}.zip"
        }
    },
    "pulsesync": {
        "zip": {
            "artifactName": "${theme.name}_${theme.version}_${build.package}.zip"
        },
        "pext": {
            "artifactName": "${theme.name}_${theme.version}_${build.package}.pext"
        }
    },
    "web": {
        "icon": "https://github.com/Diramix/Murder-Drones-Theme/blob/main/Murder%20Drones/icon.jpg?raw=true",
        "onefile": {
            "artifactName": "${theme.name}_${theme.version}_${build.package}.user.js"
        },
        "replaceLink": [
            {
                "from": "http://127.0.0.1:2007/assets/vibe.jpg?name=Murder Drones"
            },
            {
                "from": "http://127.0.0.1:2007/assets/uzi.png?name=Murder Drones"
            },
            {
                "from": "http://127.0.0.1:2007/assets/lyrics.jpg?name=Murder Drones"
            }
        ]
    },
    "devDependencies": {
        "ymtm": "github:Diramix/ymtm#2.0.0"
    }
}
